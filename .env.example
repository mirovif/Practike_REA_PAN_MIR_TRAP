# Скопируйте этот файл в .env и заполните реальными значениями

# Ключ API Mistral (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# Loginom REST веб-сервисы (4 сервиса)
LOGINOM_URL_HISTORY=https://edu.loginom.dev/lgi/rest/instacart_ws_Panichev/GetUserHistory
LOGINOM_URL_RHYTHM=https://edu.loginom.dev/lgi/rest/instacart_ws_Panichev_dop_model_3/GetUserHistory
LOGINOM_URL_FORGOTTEN=https://edu.loginom.dev/lgi/rest/instacart_ws_Panichev_dop_model_4/GetUserHistory
LOGINOM_URL_BEST_TIME=https://edu.loginom.dev/lgi/rest/instacart_ws_Panichev_dop_model/GetUserHistory

# Секретный ключ Flask для подписи сессий (любая длинная случайная строка)
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# Порт (локально и на Amvera)
PORT=8000
